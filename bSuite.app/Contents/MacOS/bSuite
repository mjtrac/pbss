#!/bin/bash
# bSuite Launcher
# Place bSuite.app in the same folder as the bSuite/ project directory,
# or inside bSuite/ itself next to bBuilder/ and bCounter/.
#
# Usage: double-click bSuite.app in Finder.

# ── Locate bSuite root ────────────────────────────────────────────────────────
BUNDLE_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
PARENT_DIR="$(dirname "$BUNDLE_DIR")"

find_suite() {
  for candidate in "$BUNDLE_DIR" "$PARENT_DIR" "$HOME/bSuite"; do
    if [ -f "$candidate/bBuilder/mvnw" ] && [ -f "$candidate/bCounter/mvnw" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

SUITE_DIR=$(find_suite)
if [ -z "$SUITE_DIR" ]; then
  osascript -e "display dialog \"Could not find bSuite project.

Looked for bBuilder/ and bCounter/ in:
  • $(dirname "$BUNDLE_DIR")
  • $HOME/bSuite

Place bSuite.app inside the bSuite/ folder (next to bBuilder/ and bCounter/).\" \
    with title \"bSuite Launcher\" buttons {\"OK\"} default button \"OK\" with icon stop"
  exit 1
fi

BUILDER_DIR="$SUITE_DIR/bBuilder"
COUNTER_DIR="$SUITE_DIR/bCounter"
HARNESS_DIR="$SUITE_DIR/test-harness"

PID_BUILDER="$SUITE_DIR/.builder_pid"
PID_COUNTER="$SUITE_DIR/.counter_pid"
LOG_BUILDER="$SUITE_DIR/bBuilder.log"
LOG_COUNTER="$SUITE_DIR/bCounter.log"

# ── Helpers ───────────────────────────────────────────────────────────────────
is_running() {
  local pidfile="$1"
  [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null
}

start_builder() {
  cd "$BUILDER_DIR" || return 1
  ./mvnw spring-boot:run >> "$LOG_BUILDER" 2>&1 &
  echo $! > "$PID_BUILDER"
}

start_counter() {
  cd "$COUNTER_DIR" || return 1
  ./mvnw spring-boot:run >> "$LOG_COUNTER" 2>&1 &
  echo $! > "$PID_COUNTER"
}

stop_app() {
  local pidfile="$1" port="$2"
  if [ -f "$pidfile" ]; then
    local pid; pid=$(cat "$pidfile")
    pkill -P "$pid" 2>/dev/null
    kill "$pid" 2>/dev/null
    rm -f "$pidfile"
  fi
  local portpid; portpid=$(lsof -ti tcp:"$port" 2>/dev/null)
  [ -n "$portpid" ] && kill "$portpid" 2>/dev/null
}

open_when_ready() {
  local url="$1"
  for i in $(seq 1 90); do
    curl -s --connect-timeout 1 "$url" >/dev/null 2>&1 && open "$url" && return
    sleep 1
  done
  open "$url"
}

status_line() {
  local pidfile="$1" name="$2" port="$3"
  if is_running "$pidfile"; then
    echo "● $name (port $port) — RUNNING"
  else
    echo "○ $name (port $port) — stopped"
  fi
}

builder_running() { is_running "$PID_BUILDER"; }
counter_running() { is_running "$PID_COUNTER"; }
both_running()    { builder_running && counter_running; }

# ── Start both ────────────────────────────────────────────────────────────────
start_all() {
  local opened_browser=0
  if ! builder_running; then
    start_builder
    open_when_ready "http://localhost:8080" &
    opened_browser=1
  fi
  if ! counter_running; then
    start_counter
    open_when_ready "http://localhost:8081" &
    opened_browser=1
  fi
  if [ "$opened_browser" -eq 0 ]; then
    osascript -e 'display dialog "Both bBuilder and bCounter are already running." \
      with title "bSuite Launcher" buttons {"OK"} default button "OK"'
  else
    osascript -e 'display dialog "Starting bSuite…

The browser will open when each service is ready.
(First run may take 1–3 minutes while Maven downloads dependencies.)" \
      with title "bSuite Launcher" buttons {"OK"} default button "OK"'
  fi
}

# ── Run test harness ──────────────────────────────────────────────────────────
run_test_harness() {
  if ! both_running; then
    osascript -e 'display dialog "Both bBuilder and bCounter must be running before starting the test harness.

Please choose \"Start All\" first, wait for both to be ready, then try again." \
      with title "bSuite Launcher" buttons {"OK"} default button "OK" with icon caution'
    return
  fi

  if [ ! -d "$HARNESS_DIR" ]; then
    osascript -e "display dialog \"Test harness not found at:\n$HARNESS_DIR\" \
      with title \"bSuite Launcher\" buttons {\"OK\"} default button \"OK\" with icon stop"
    return
  fi

  # Ask: fresh run (reset + run_all) or just rescan existing images
  local MODE
  MODE=$(osascript <<EOF
set MODE to choose from list {"Full run (regenerate everything)", "Rescan only (use existing images)"} ¬
  with title "bSuite Test Harness" ¬
  with prompt "Choose test run type:" ¬
  default items {"Full run (regenerate everything)"} ¬
  without multiple selections allowed and empty selection allowed
if MODE is false then return "cancel"
return item 1 of MODE
EOF
)

  [ "$MODE" = "cancel" ] || [ -z "$MODE" ] && return

  # Open a new Terminal window and run the harness there so output is visible
  if [ "$MODE" = "Full run (regenerate everything)" ]; then
    # Stop bCounter, reset, restart it, then run_all
    osascript -e 'display dialog "The test harness will:
1. Stop bCounter
2. Reset the scan database and image files
3. Restart bCounter
4. Run run_all.sh (generates ballots, marks them, distorts them, scans, verifies)

This takes several minutes. Output will appear in a Terminal window." \
      with title "bSuite Test Harness" buttons {"Cancel", "Start"} default button "Start" cancel button "Cancel"'
    [ $? -ne 0 ] && return

    # Write a helper script that Terminal will run
    local tmpscript
    tmpscript=$(mktemp /tmp/bsuite_harness_XXXXXX.sh)
    cat > "$tmpscript" << SCRIPT
#!/bin/bash
set -e
echo "═══════════════════════════════════════════════════════"
echo "  bSuite Test Harness — Full Run"
echo "═══════════════════════════════════════════════════════"

echo ""
echo "Step 1 — Stopping bCounter..."
PID_COUNTER_FILE="$PID_COUNTER"
if [ -f "\$PID_COUNTER_FILE" ]; then
  pid=\$(cat "\$PID_COUNTER_FILE")
  pkill -P "\$pid" 2>/dev/null; kill "\$pid" 2>/dev/null
  rm -f "\$PID_COUNTER_FILE"
fi
portpid=\$(lsof -ti tcp:8081 2>/dev/null)
[ -n "\$portpid" ] && kill "\$portpid" 2>/dev/null
sleep 2

echo "Step 2 — Resetting scan state..."
cd "$HARNESS_DIR"
./reset_scan.sh

echo "Step 3 — Restarting bCounter..."
cd "$COUNTER_DIR"
./mvnw spring-boot:run >> "$LOG_COUNTER" 2>&1 &
echo \$! > "$PID_COUNTER"
echo "  Waiting for bCounter to be ready..."
for i in \$(seq 1 90); do
  curl -s --connect-timeout 1 http://localhost:8081/login >/dev/null 2>&1 && break
  sleep 1
done
echo "  ✓ bCounter ready"

echo "Step 4 — Running test harness..."
cd "$HARNESS_DIR"
./run_all.sh --counter-dir "$COUNTER_DIR"

echo ""
echo "═══════════════════════════════════════════════════════"
echo "  Test harness complete. Press Return to close."
echo "═══════════════════════════════════════════════════════"
read
SCRIPT
    chmod +x "$tmpscript"
    open -a Terminal "$tmpscript"

  else
    # Rescan only — just run run_counter.py in a Terminal window
    osascript -e 'display dialog "The test harness will rescan existing images using the current database.

Output will appear in a Terminal window." \
      with title "bSuite Test Harness" buttons {"Cancel", "Start"} default button "Start" cancel button "Cancel"'
    [ $? -ne 0 ] && return

    local tmpscript
    tmpscript=$(mktemp /tmp/bsuite_rescan_XXXXXX.sh)
    cat > "$tmpscript" << SCRIPT
#!/bin/bash
echo "═══════════════════════════════════════════════════════"
echo "  bSuite — Rescan Existing Images"
echo "═══════════════════════════════════════════════════════"
cd "$HARNESS_DIR"

# Find python3
PYTHON3=\$(command -v python3 || echo "python3")

# Find YAML dir
YAML_DIR="\$HOME/bBuilder_ballots"
[ -d "\$YAML_DIR" ] || YAML_DIR="$BUILDER_DIR"

echo ""
"\$PYTHON3" run_counter.py --images images --yaml-dir "\$YAML_DIR"
echo ""
echo "═══════════════════════════════════════════════════════"
echo "  Rescan complete. Press Return to close."
echo "═══════════════════════════════════════════════════════"
read
SCRIPT
    chmod +x "$tmpscript"
    open -a Terminal "$tmpscript"
  fi
}

# ── Main menu loop ────────────────────────────────────────────────────────────
while true; do
  BS=$(status_line "$PID_BUILDER" "bBuilder (Ballot Designer)" 8080)
  CS=$(status_line "$PID_COUNTER" "bCounter (Scanner & Viewer)" 8081)

  CHOICE=$(osascript <<EOF
set menuItems to { ¬
  "── Start / Open ──────────────────", ¬
  "Start All (bBuilder + bCounter)", ¬
  "Start bBuilder only", ¬
  "Start bCounter only", ¬
  "Open bBuilder in Browser", ¬
  "Open bCounter in Browser", ¬
  "Open bViewer in Browser", ¬
  "── Test Harness ──────────────────", ¬
  "Run Test Harness…", ¬
  "── Stop ──────────────────────────", ¬
  "Stop All", ¬
  "Quit"}
set CHOICE to choose from list menuItems ¬
  with title "bSuite Launcher" ¬
  with prompt "${BS}
${CS}

Choose an action:" ¬
  default items {"Start All (bBuilder + bCounter)"} ¬
  without multiple selections allowed and empty selection allowed
if CHOICE is false then return "Quit"
return item 1 of CHOICE
EOF
)

  [ -z "$CHOICE" ] && CHOICE="Quit"

  case "$CHOICE" in

    "── Start / Open ──────────────────" | \
    "── Test Harness ──────────────────" | \
    "── Stop ──────────────────────────")
      # Separator items — loop back
      ;;

    "Start All (bBuilder + bCounter)")
      start_all
      ;;

    "Start bBuilder only")
      if builder_running; then
        osascript -e 'display dialog "bBuilder is already running." \
          with title "bSuite Launcher" buttons {"OK"} default button "OK"'
      else
        osascript -e 'display dialog "Starting bBuilder…\n\nThe browser will open when it is ready." \
          with title "bSuite Launcher" buttons {"OK"} default button "OK"'
        start_builder
        open_when_ready "http://localhost:8080" &
      fi
      ;;

    "Start bCounter only")
      if counter_running; then
        osascript -e 'display dialog "bCounter is already running." \
          with title "bSuite Launcher" buttons {"OK"} default button "OK"'
      else
        osascript -e 'display dialog "Starting bCounter…\n\nThe browser will open when it is ready.\nbViewer will also be available on port 8082." \
          with title "bSuite Launcher" buttons {"OK"} default button "OK"'
        start_counter
        open_when_ready "http://localhost:8081" &
      fi
      ;;

    "Open bBuilder in Browser")
      open "http://localhost:8080"
      ;;

    "Open bCounter in Browser")
      open "http://localhost:8081"
      ;;

    "Open bViewer in Browser")
      open "http://localhost:8082/viewer/"
      ;;

    "Run Test Harness…")
      run_test_harness
      ;;

    "Stop All")
      stop_app "$PID_BUILDER" 8080
      stop_app "$PID_COUNTER" 8081
      osascript -e 'display dialog "bBuilder and bCounter have been stopped." \
        with title "bSuite Launcher" buttons {"OK"} default button "OK"'
      ;;

    "Quit")
      if builder_running || counter_running; then
        ANS=$(osascript -e 'button returned of (display dialog "Stop running services before quitting?" \
          with title "bSuite Launcher" buttons {"Leave Running", "Stop & Quit"} default button "Stop & Quit")')
        if [ "$ANS" = "Stop & Quit" ]; then
          stop_app "$PID_BUILDER" 8080
          stop_app "$PID_COUNTER" 8081
        fi
      fi
      exit 0
      ;;

  esac
done
