# test-harness/.gitignore

# Generated ballot images and distorted copies — large binary files,
# regenerated by run_all.sh from the marked_ballots folder. Named {dpi}_images/
# for non-default DPI (e.g. 150_images/), or plain images/ at 300 DPI.
images/
*_images/

# Marked ballot PNGs — generated by mark_ballots.py from bBuilder PDFs.
# ground_truth.json is also regenerated, so exclude the whole folder.
marked_ballots/

# Election data output — regenerated by build_election.py each run.
election_data.json

# Desktop GUI pipeline — see README-desktop.md. Generated corpus + results
# DBs/reports, all regenerated by run_desktop_gui_pipeline.sh.
desktop_pipeline/

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
.venv/
