# test-harness/.gitignore

# Generated ballot images and distorted copies — large binary files,
# regenerated by run_all.sh from the marked_ballots folder.
images/

# Marked ballot PNGs — generated by mark_ballots.py from bBuilder PDFs.
# ground_truth.json is also regenerated, so exclude the whole folder.
marked_ballots/

# Election data output — regenerated by build_election.py each run.
election_data.json

# Python cache
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
