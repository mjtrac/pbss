<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.mjtrac</groupId>
  <artifactId>bBuilder</artifactId>
  <version>0.9.18</version>
  <packaging>jar</packaging>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <!--
      SECURITY NOTE: Always use the latest Spring Boot 3.x patch release.
      Monitor https://spring.io/security for CVE advisories.
    -->
    <version>3.3.0</version>
  </parent>

  <properties>
    <!--
      Compiled at Java 21 language level for LTS stability.
      Compatible with Java 21, 22, 23, 24, 25+ at runtime.
      The maven.compiler.release property enforces source/target bytecode level,
      not which JDK you use to build.
    -->
    <java.version>21</java.version>
    <maven.compiler.release>21</maven.compiler.release>

    <itext.version>8.0.4</itext.version>
    <zxing.version>3.5.3</zxing.version>
    <snakeyaml.version>2.2</snakeyaml.version>
    <sqlite.version>3.45.3.0</sqlite.version>
  </properties>

  <dependencies>

    <!-- Shared ballot-design engine (model, repository, util, generation
         services) — see builder-core/README.md. Requires `mvn install`
         from ~/pbss2/builder-core before building this module for the
         first time (or after a builder-core change). -->
    <dependency>
      <groupId>com.mjtrac</groupId>
      <artifactId>builder-core</artifactId>
      <version>0.9.18</version>
    </dependency>

    <!-- ── Spring Boot Web + Thymeleaf UI ───────────────────────────── -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-thymeleaf</artifactId>
    </dependency>

    <!-- ── Spring Security ──────────────────────────────────────────── -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-security</artifactId>
    </dependency>
    <dependency>
      <groupId>org.thymeleaf.extras</groupId>
      <artifactId>thymeleaf-extras-springsecurity6</artifactId>
    </dependency>

    <!-- ── JPA / Hibernate ──────────────────────────────────────────── -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-data-jpa</artifactId>
    </dependency>

    <!-- ── SQLite (Apache 2.0) ──────────────────────────────────────── -->
    <dependency>
      <groupId>org.xerial</groupId>
      <artifactId>sqlite-jdbc</artifactId>
      <version>${sqlite.version}</version>
    </dependency>
    <!-- Hibernate community dialect for SQLite (Apache 2.0) -->
    <dependency>
      <groupId>org.hibernate.orm</groupId>
      <artifactId>hibernate-community-dialects</artifactId>
    </dependency>

    <!-- ── PostgreSQL (BSD 2-Clause) ────────────────────────────────── -->
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <scope>runtime</scope>
    </dependency>

    <!-- ── Testing ───────────────────────────────────────────────────── -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
      <exclusions>
        <!-- Exclude inline mock maker; use subclass maker for Java 25 compatibility -->
        <exclusion>
          <groupId>org.mockito</groupId>
          <artifactId>mockito-inline</artifactId>
        </exclusion>
      </exclusions>
    </dependency>

    <!-- H2 in-memory DB for integration tests -->
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Mockito subclass mock maker: works on Java 25 without add-opens -->
    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-subclass</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.springframework.security</groupId>
      <artifactId>spring-security-test</artifactId>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <build>
    <plugins>
      <!-- Surefire: open modules needed by Mockito + Spring on Java 21+ -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <argLine>
            --add-opens java.base/java.lang=ALL-UNNAMED
            --add-opens java.base/java.util=ALL-UNNAMED
            --add-opens java.base/java.lang.reflect=ALL-UNNAMED
          </argLine>
        </configuration>
      </plugin>
      <!-- Explicit compiler configuration -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <release>21</release>
          <parameters>true</parameters>
        </configuration>
      </plugin>

      <!-- Fat/uber JAR for single-file distribution -->
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
    </plugins>
  </build>

</project>
